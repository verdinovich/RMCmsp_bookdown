#' Generate uncertainty estimates for fitted MSP model
#'
#' @param msp_fit Object returned from the revised fit_msp function.
#' @param method Method by which uncertainty is quantified. \code{"mvn"} samples parameter
#'   sets from a multivariate normal distribution centred on the joint MSP fitted values,
#'   using the sandwich-corrected covariance matrix. Requires a successfully converged joint
#'   model (\code{msp_fit$general_msp_status == "converged"}); if the joint model failed,
#'   an informative error is raised and \code{"boot"} is recommended instead.
#'   \code{"boot"} uses a parametric bootstrap: data are simulated from the fitted MSP,
#'   transformed to GEV space, and the joint model is re-fitted to each replicate. This
#'   method can fall back to \code{initial_msp} + \code{spatial_gev} parameter estimates
#'   when \code{general_msp} is unavailable.
#' @param nsims Number of parameter samples (mvn) or bootstrap replicates (boot).
#'   Default 300.
#' @param covar.mod Covariance model string, required for \code{method = "boot"}.
#'   One of \code{"tpowexp"}, \code{"tcauchy"}, \code{"twhitmat"}, \code{"tbessel"},
#'   \code{"tcaugen"}. Defaults to the same model used in \code{fit_msp}.
#' @param mvn_max_attempts Maximum number of MVN draw attempts per sample before giving
#'   up on the positivity constraint. Prevents infinite loops when the covariance matrix
#'   is poorly conditioned. Default 10000.
#'
#' @return A list with: \code{param_samples} (matrix, rows = samples, cols = parameters),
#'   \code{uncertainty_method}, \code{general_msp_used} (logical), and \code{msp_fit}.
#' @export
#'
#' @examples
#' \dontrun{
#' msp_workspace <- msp_setup(anmax=mc_anmax, metadata=mc_meta,
#'                             prism_rasters=mc_prism, subbasin_targets=mc_targets)
#' msp_model     <- fit_msp(msp_workspace=msp_workspace, covar.mod='twhitmat')
#' msp_mvn_unc   <- msp_uncertainty(msp_fit=msp_model, method="mvn", nsims=100)
#' msp_boot_unc  <- msp_uncertainty(msp_fit=msp_model, method="boot", nsims=100)
#' }
msp_uncertainty <- function(msp_fit, method = c("mvn", "boot"),
                            nsims = 300, covar.mod = NULL,
                            mvn_max_attempts = 10000) {

  # Fixed nugget used in all rmaxstab/fitmaxstab calls. Must match the value
  # used in fit_msp() to keep the inter-site correlation matrix positive definite.
  # Not exposed as a user argument intentionally.
  nugget <- 0.01

  method <- match.arg(method)

  # Determine whether the joint model converged
  general_msp_ok <- !is.null(msp_fit$general_msp) &&
                    identical(msp_fit$general_msp_status, "converged")

  ############################################################################
  # MVN METHOD
  ############################################################################

  if (method == "mvn") {

    # MVN requires a valid joint covariance matrix - cannot fall back
    if (!general_msp_ok) {
      stop(paste0(
        "method = 'mvn' requires a successfully converged joint MSP model, but ",
        "msp_fit$general_msp_status is '", msp_fit$general_msp_status, "'. ",
        "The multivariate normal approximation needs both fitted.values (the mean vector) ",
        "and var.cov (the covariance matrix) from the joint fit, which are unavailable.\n\n",
        "Options:\n",
        "  1. Use method = 'boot' instead - it can fall back to initial_msp + spatial_gev.\n",
        "  2. Revisit data quality, study area extent, or covariance model (see fit_msp warning).\n"
      ))
    }

    # Also check that var.cov is usable (non-NULL, finite, square)
    vc <- msp_fit$general_msp$var.cov
    fv <- msp_fit$general_msp$fitted.values
    if (is.null(vc) || !is.matrix(vc) || !all(is.finite(vc))) {
      stop(paste0(
        "msp_fit$general_msp$var.cov is NULL, non-matrix, or contains non-finite values. ",
        "Cannot sample from MVN. Use method = 'boot' instead."
      ))
    }

    covars <- msp_fit$msp_workspace$covar_normalized

    # Scale predictor matrix for the positivity-of-scale constraint check
    scl.mat    <- as.matrix(stats::coef(msp_fit$msp_workspace$glmnet_cvfit_scale))
    scale.vars <- row.names(scl.mat)[scl.mat != 0]
    # Predictor variables = all selected vars except "(Intercept)"
    scale.pred.vars <- scale.vars[scale.vars != "(Intercept)"]

    if (length(scale.pred.vars) == 0) {
      # Intercept-only scale model: design matrix is just a column of 1s
      scale.covs <- matrix(1, nrow = nrow(covars), ncol = 1)
    } else {
      scale.prism.id <- which(colnames(covars) %in% scale.pred.vars)
      scale.covs     <- cbind(1, as.matrix(covars[, scale.prism.id, drop = FALSE]))
    }

    # Parameter indices for constraints
    spat.id  <- which(names(fv) %in% c("range", "smooth", "DoF"))
    scale.id <- grep("^scale", names(fv))

    # Sample from MVN, enforcing positivity constraints
    param_samples <- matrix(NA, nrow = nsims, ncol = length(fv))

    for (i in seq_len(nsims)) {
      attempts <- 0L
      repeat {
        attempts <- attempts + 1L
        if (attempts > mvn_max_attempts) {
          stop(paste0(
            "MVN sampling failed to satisfy positivity constraints after ",
            mvn_max_attempts, " attempts at sample ", i, ". ",
            "The covariance matrix may be poorly conditioned. ",
            "Consider method = 'boot' or revisiting the joint model fit."
          ))
        }
        samp <- MASS::mvrnorm(n = 1, mu = fv, Sigma = vc)
        if (!any(samp[spat.id] <= 0) &&
            !any(scale.covs %*% samp[scale.id] <= 0)) break
      }
      param_samples[i, ] <- samp
    }

    colnames(param_samples) <- names(fv)

    return(list(
      param_samples      = param_samples,
      uncertainty_method = method,
      general_msp_used   = TRUE,
      msp_fit            = msp_fit
    ))
  }

  ############################################################################
  # BOOT METHOD
  ############################################################################

  if (method == "boot") {

    # Covariance model: inherit from whichever model is available
    valid.mods <- c("tpowexp", "tcauchy", "twhitmat", "tbessel", "tcaugen")
    if (is.null(covar.mod)) {
      covar.mod <- if (general_msp_ok) {
        msp_fit$general_msp$cov.mod
      } else {
        msp_fit$initial_msp$cov.mod
      }
      if (is.null(covar.mod)) covar.mod <- "twhitmat"
      print(paste("Using covariance model inherited from fit_msp:", covar.mod))
    } else {
      if (!covar.mod %in% valid.mods) {
        stop(paste0(
          "covar.mod '", covar.mod, "' not supported. ",
          "Choose one of: ", paste(valid.mods, collapse = ", "), "."
        ))
      }
      print(paste("User-defined covariance model:", covar.mod))
    }

    coords_norm <- subset(msp_fit$msp_workspace$covar_normalized,
                          select = c("X.pts", "Y.pts"))

    # Internal helper: check covariance parameters for non-finite values before
    # passing to rmaxstab. Returns a named vector c(range, smooth, DoF).
    # Bounds clamping is intentionally omitted - valid ranges for the
    # SpatialExtremes covariance parameters should be confirmed from the package
    # source before any clamping is added here.
    .validate_cosp <- function(range_v, smooth_v, DoF_v) {
      if (any(!is.finite(c(range_v, smooth_v, DoF_v)))) {
        stop(paste0(
          "Covariance parameters (range/smooth/DoF) contain non-finite values. ",
          "Cannot generate bootstrap data. Check fit_msp() output."
        ))
      }
      c(range = range_v, smooth = smooth_v, DoF = DoF_v)
    }

    # Internal helper: simulate nsims Frechet fields and return as a list.
    # Each failed replicate is stored as NULL.
    .simulate_frechet <- function(range_v, smooth_v, DoF_v) {
      out <- vector("list", nsims)
      n_fail <- 0L
      for (i in seq_len(nsims)) {
        out[[i]] <- tryCatch({
          sim_i <- SpatialExtremes::rmaxstab(
            n       = nrow(msp_fit$msp_workspace$anmax),
            coord   = coords_norm,
            cov.mod = covar.mod,
            range   = range_v,
            smooth  = smooth_v,
            DoF     = DoF_v,
            nugget  = nugget
          )
          sim_i[is.na(msp_fit$msp_workspace$anmax)] <- NA
          sim_i
        }, error = function(e) { n_fail <<- n_fail + 1L; NULL })
      }
      n_ok <- sum(!sapply(out, is.null))
      if (n_fail > 0) {
        warning(paste0(
          n_fail, " of ", nsims, " rmaxstab simulation(s) failed (LAPACK Cholesky error). ",
          "Those replicates are NULL and will be skipped."
        ))
      }
      if (n_ok == 0) {
        stop(paste0(
          "All ", nsims, " rmaxstab simulations failed. The correlation matrix is not ",
          "positive definite for range=", range_v, ", smooth=", smooth_v,
          ", DoF=", DoF_v, ". ",
          "Review the covariance parameters in fit_msp() output."
        ))
      }
      out
    }

    ############################################################################
    # PATH A: general_msp converged - parametric bootstrap with joint refit
    ############################################################################

    if (general_msp_ok) {

      print(paste0(
        "Preparing to bootstrap the general MSP model (joint refit). ",
        "This will take a while..."
      ))

      fv_all <- msp_fit$general_msp$fitted.values

      cosp <- .validate_cosp(
        as.numeric(fv_all["range"]),
        as.numeric(fv_all["smooth"]),
        as.numeric(fv_all["DoF"])
      )

      # Simulate Frechet fields from the joint fitted model
      sims <- .simulate_frechet(cosp["range"], cosp["smooth"], cosp["DoF"])

      # Transform to GEV using the joint model's predicted marginals
      preds  <- stats::predict(msp_fit$general_msp)
      locs   <- preds[, "loc"]
      scales <- preds[, "scale"]
      shapes <- preds[, "shape"]

      sims_gev <- sims
      for (i in seq_len(nsims)) {
        if (is.null(sims[[i]])) next
        for (j in seq_len(ncol(msp_fit$msp_workspace$anmax))) {
          sims_gev[[i]][, j] <- SpatialExtremes::frech2gev(
            sims[[i]][, j], locs[j], scales[j], shapes[j]
          )
        }
      }

      # Re-fit the joint model to each bootstrap replicate (parallel)
      start_general  <- as.list(fv_all)
      loc.form.obj   <- stats::as.formula(msp_fit$loc.form)
      scale.form.obj <- stats::as.formula(msp_fit$scale.form)
      shape.form.obj <- stats::as.formula(msp_fit$shape.form)

      n.cores    <- ceiling(as.numeric(parallel::detectCores()) / 2)
      my.cluster <- parallel::makeCluster(n.cores, type = "PSOCK")
      doParallel::registerDoParallel(cl = my.cluster)
      `%dopar%` <- foreach::`%dopar%`

      fits <- foreach::foreach(
        i = seq_len(nsims),
        .errorhandling = "pass",
        .packages = "SpatialExtremes"
      ) %dopar% {
        if (is.null(sims_gev[[i]])) return(NULL)
        tryCatch({
          SpatialExtremes::fitmaxstab(
            data       = sims_gev[[i]],
            coord      = coords_norm,
            cov.mod    = covar.mod,
            marg.cov   = msp_fit$msp_workspace$covar_normalized,
            fit.marge  = TRUE,
            loc.form   = loc.form.obj,
            scale.form = scale.form.obj,
            shape.form = shape.form.obj,
            start      = start_general,
            nugget     = nugget
          )
        }, error = function(e) NULL)
      }

      parallel::stopCluster(cl = my.cluster)

      n_ok   <- sum(sapply(fits, function(f) !is.null(f) && !is.null(f$fitted.values)))
      n_fail <- nsims - n_ok
      if (n_fail > 0) {
        warning(paste0(
          n_fail, " of ", nsims, " bootstrap joint refits failed and will be NA rows ",
          "in param_samples. Consider increasing nsims or reviewing starting values."
        ))
      }
      if (n_ok == 0) {
        stop("All bootstrap joint refits failed. Cannot construct param_samples.")
      }

      param_samples <- matrix(NA, nrow = nsims, ncol = length(fv_all))
      for (i in seq_len(nsims)) {
        fi <- fits[[i]]
        if (!is.null(fi) && !is.null(fi$fitted.values) &&
            length(fi$fitted.values) == ncol(param_samples)) {
          param_samples[i, ] <- as.numeric(fi$fitted.values)
        }
      }
      colnames(param_samples) <- names(fv_all)

    ############################################################################
    # PATH B: general_msp did not converge - bootstrap initial_msp + spatial_gev
    # separately; no joint refit attempted.
    ############################################################################

    } else {

      warning(paste0(
        "general_msp did not converge (status: '", msp_fit$general_msp_status, "'). ",
        "Switching to a separated bootstrap: the MSP process is simulated from ",
        "initial_msp covariance parameters, and independent bootstrap samples of the ",
        "spatial GEV marginal parameters are drawn by resampling the observed annual ",
        "maxima with replacement and refitting fitspatgev. ",
        "Bootstrap uncertainty reflects variability around the initial_msp and ",
        "spatial_gev estimates rather than a joint fit."
      ))

      print(paste0(
        "Preparing to bootstrap initial_msp + spatial_gev (no joint refit). ",
        "This will take a while..."
      ))

      # --- Covariance bootstrap: resample from initial_msp ---
      fv_cosp <- msp_fit$initial_msp$fitted.values
      cosp    <- .validate_cosp(
        as.numeric(fv_cosp["range"]),
        as.numeric(fv_cosp["smooth"]),
        as.numeric(fv_cosp["DoF"])
      )

      # Simulate Frechet fields from the initial MSP covariance parameters
      sims_frech <- .simulate_frechet(cosp["range"], cosp["smooth"], cosp["DoF"])

      # Re-fit initial_msp (no marginals) to each Frechet bootstrap replicate
      start_init <- as.list(fv_cosp)

      n.cores    <- ceiling(as.numeric(parallel::detectCores()) / 2)
      my.cluster <- parallel::makeCluster(n.cores, type = "PSOCK")
      doParallel::registerDoParallel(cl = my.cluster)
      `%dopar%` <- foreach::`%dopar%`

      fits_cosp <- foreach::foreach(
        i = seq_len(nsims),
        .errorhandling = "pass",
        .packages = "SpatialExtremes"
      ) %dopar% {
        if (is.null(sims_frech[[i]])) return(NULL)
        tryCatch({
          SpatialExtremes::fitmaxstab(
            data    = sims_frech[[i]],
            coord   = coords_norm,
            cov.mod = covar.mod,
            start   = start_init,
            nugget  = nugget
          )
        }, error = function(e) NULL)
      }

      parallel::stopCluster(cl = my.cluster)

      # --- Marginal bootstrap: resample anmax rows, refit spatial GEV ---
      fv_gev  <- msp_fit$spatial_gev$fitted.values
      anmax   <- msp_fit$msp_workspace$anmax
      covnorm <- msp_fit$msp_workspace$covar_normalized

      loc.form.obj   <- stats::as.formula(msp_fit$loc.form)
      scale.form.obj <- stats::as.formula(msp_fit$scale.form)
      shape.form.obj <- stats::as.formula(msp_fit$shape.form)

      n.cores    <- ceiling(as.numeric(parallel::detectCores()) / 2)
      my.cluster <- parallel::makeCluster(n.cores, type = "PSOCK")
      doParallel::registerDoParallel(cl = my.cluster)

      fits_gev <- foreach::foreach(
        i = seq_len(nsims),
        .errorhandling = "pass",
        .packages = "SpatialExtremes"
      ) %dopar% {
        tryCatch({
          boot_anmax <- anmax[sample(nrow(anmax), replace = TRUE), ]
          SpatialExtremes::fitspatgev(
            data     = boot_anmax,
            covariables = covnorm,
            loc.form = loc.form.obj,
            scale.form = scale.form.obj,
            shape.form = shape.form.obj,
            control  = list(maxit = 500000)
          )
        }, error = function(e) NULL)
      }

      parallel::stopCluster(cl = my.cluster)

      # Summarise success rates for both components
      n_ok_cosp <- sum(sapply(fits_cosp, function(f) !is.null(f) && !is.null(f$fitted.values)))
      n_ok_gev  <- sum(sapply(fits_gev,  function(f) !is.null(f) && !is.null(f$fitted.values)))
      if ((nsims - n_ok_cosp) > 0)
        warning(paste0(nsims - n_ok_cosp, " of ", nsims, " initial_msp bootstrap refits failed."))
      if ((nsims - n_ok_gev) > 0)
        warning(paste0(nsims - n_ok_gev,  " of ", nsims, " spatial_gev bootstrap refits failed."))
      if (n_ok_cosp == 0 || n_ok_gev == 0)
        stop("All bootstrap refits failed for at least one component. Cannot construct param_samples.")

      # Assemble combined parameter matrix: covariance params | GEV marginal params
      fv_all        <- c(fv_cosp, fv_gev)
      n_cosp        <- length(fv_cosp)
      n_gev         <- length(fv_gev)
      param_samples <- matrix(NA, nrow = nsims, ncol = n_cosp + n_gev)

      for (i in seq_len(nsims)) {
        fc <- fits_cosp[[i]]
        fg <- fits_gev[[i]]
        cosp_ok <- !is.null(fc) && !is.null(fc$fitted.values) && length(fc$fitted.values) == n_cosp
        gev_ok  <- !is.null(fg) && !is.null(fg$fitted.values) && length(fg$fitted.values) == n_gev
        if (cosp_ok && gev_ok) {
          param_samples[i, ] <- c(as.numeric(fc$fitted.values), as.numeric(fg$fitted.values))
        }
        # Row stays NA if either component failed; downstream can na.omit
      }
      colnames(param_samples) <- names(fv_all)
    }

    return(list(
      param_samples      = param_samples,
      uncertainty_method = method,
      general_msp_used   = general_msp_ok,
      msp_fit            = msp_fit
    ))
  }
}
