#' Simulate from the MSP model at target locations and transform from Frechet to GEV space
#'
#' @param msp_uncertainty Output from msp_uncertainty function.
#' @param msp_fit Output from fit_msp function.
#' @param subbasin_targets A matrix with the subbasin target locations. These are the raw coordinates, NOT normalized from msp_setup( ). These are used to extract trend raster values.
#' @param target_weights A vector of length equal to nrow(subbasin_targets), corresponding to the area each subbasin target represents. These are used to calculate the basin average precipitation-frequency curves.
#' @param nsims Number of simulations for each MSP model. Defaults to 100,000 (rule of thumb: use one order of magnitude more than the desired return period (e.g., nsims = 100,000 ; 1/10,000 return period approximation))
#' @param nsamples Optional; default is to use all bootstrapped samples. User can specify a subset for testing /sensitivity
#' @param ncores How many cores to do you want to use on your machine? default is 1/2 of available. If user specifies too many, revert to default.
#'
#' @return A list of length nsims
#' @export
#'
#' @examples
#' \dontrun{
#' msp_workspace <- msp_setup(anmax=mc_anmax, metadata=mc_meta,
#'                             prism_rasters=mc_prism, subbasin_targets=mc_targets)
#' msp_model     <- fit_msp(msp_workspace=msp_workspace, covar.mod='twhitmat')
#' msp_mvn_unc   <- msp_uncertainty(msp_fit=msp_model, method="mvn", nsims=100)
#' msp_sims      <- simulate_from_msp(msp_mvn_unc, msp_model)
#' }
simulate_from_msp <- function(msp_uncertainty, msp_fit, subbasin_targets, target_weights=NULL, nsims=100000, nsamples=NULL, ncores=NULL){

  # load the samples
  samples <- msp_uncertainty$param_samples

  # check target_weights
  if(is.null(target_weights)){
    print("target_weights not specified. Final GEV curve will use mean() instead of weighted.mean()")
    target_weights <- rep(1, nrow(msp_fit$msp_workspace$targets_normalized))
  }

  # optionally simulate only a subset of bootstraps, defaults to all
  if(is.null(nsamples)){
    nsamples <- nrow(samples)
  }

  # if user specifies too many samples, just use all bootstraps
  if(nsamples > nrow(samples)){
    nsamples <- nrow(samples)
    print(paste0("Number of samples specified exceeded total number of samples. nsamples is now equal to ",nsamples))
  }

  # subset samples prior to simulations
  X <- as.data.frame(samples[1:nsamples,])

  # parallel setup
  if(is.null(ncores)){
    ncores <- ceiling(parallel::detectCores() / 2)
    print(paste("Parallel environment set up using",ncores,"cores."))
  }

  # override user error with ncores
  if(ncores > as.numeric(parallel::detectCores())){
    ncores <- ceiling(parallel::detectCores() / 2)
    print(paste("User specified too many cores. Setting up parallel environment using",ncores,"cores."))
  }

  #create the cluster
  my.cluster <- parallel::makeCluster(ncores, type = "PSOCK")

  #register it to be used by %dopar%
  doParallel::registerDoParallel(cl = my.cluster)
  `%dopar%` <- foreach::`%dopar%`

  print("Beginning MSP simulation using the parallel environment...")

  # simulate from the sampled model parameters
  xs = 1:(nsamples)
  progressr::with_progress({
    # Initialize a progressor with total number of steps
    p <- progressr::progressor(along = xs)

    # Update the progressor while running the rmaxstab call
    sims <- foreach::foreach(i = 1:(nsamples), .errorhandling = "pass", .packages="SpatialExtremes") %dopar% {
      p()
      SpatialExtremes::rmaxstab(n=nsims, coord=as.matrix(msp_fit$msp_workspace$targets_normalized), cov.mod="twhitmat", nugget=0.01,
                                range=X$range[i], smooth=X$smooth[i], DoF=X$DoF[i])
  }})

  # stop the cluster!
  parallel::stopCluster(cl = my.cluster)

  # simulate from the fitted model (nugget fixed for now)
  sims.fit = SpatialExtremes::rmaxstab(n=nsims, coord=as.matrix(msp_fit$msp_workspace$targets_normalized), cov.mod="twhitmat", nugget=0.01,
                                       range=msp_fit$general_msp$fitted.values[1], smooth=msp_fit$general_msp$fitted.values[2], DoF=msp_fit$general_msp$fitted.values[3])

  # append the simulated from the fitted model to the bootstrapped simulations list
  sims[[(length(sims) + 1)]] = sims.fit


  ############################################################################
  # build trend rasters
  ############################################################################

  # pull the rasters from the msp_workspace
  raster_list0 <- msp_fit$msp_workspace$prism_rasters

  # pull the mean and std used to normalize covariates at site
  col_means <- msp_fit$msp_workspace$covar_colmean
  col_stds  <- msp_fit$msp_workspace$covar_colstd

  # strip the '.pts' from their names to align with the raster names
  names(col_means) <- unlist(strsplit(names(col_means), split=".pts"))
  names(col_stds)  <- unlist(strsplit(names(col_stds),  split=".pts"))

  # normalize the rasters using the means and stdeves
  raster_list <- mapply(function(r, m, s) (r - m) / s,
                        raster_list0[names(col_means)[names(col_means) %in% names(raster_list0)]],
                        col_means[names(col_means) %in% names(raster_list0)],
                        col_stds[names(col_stds)   %in% names(raster_list0)],
                        SIMPLIFY = FALSE)

  # force all CRS to be equal
  ref_crs <- terra::crs(terra::rast(raster_list[[1]]))
  raster_list <- lapply(raster_list, function(r) {
    if(!inherits(r, "SpatRaster")) r <- terra::rast(r)
    terra::crs(r) <- ref_crs
    r
  })

  # Crop to common extent
  common_ext <- Reduce(terra::intersect, lapply(raster_list, terra::ext))
  raster_list <- lapply(raster_list, function(r) terra::crop(r, common_ext))

  # pull the variable names from elastic net results, stripping '.pts'
  loc.mat <- as.matrix(stats::coef(msp_fit$msp_workspace$glmnet_cvfit_loc))
  scl.mat <- as.matrix(stats::coef(msp_fit$msp_workspace$glmnet_cvfit_scale))
  shp.mat <- as.matrix(stats::coef(msp_fit$msp_workspace$glmnet_cvfit_shape))

  strip_pts <- function(x) unlist(strsplit(x, split=".pts"))

  loc.vars <- strip_pts(row.names(loc.mat))
  scl.vars <- strip_pts(row.names(scl.mat))
  shp.vars <- strip_pts(row.names(shp.mat))

  # pull bootstrapped samples
  bootstraps <- X

  # helper function to build a trend raster from a coefficient vector
  # coef_vec: named or positional vector where [1] is intercept, [2:] are slope coefficients
  # vars: variable names corresponding to coef_vec (first entry is "(Intercept"))
  build_trend_raster <- function(coef_vec, vars){
    raster_subset <- raster_list[vars[-1]]
    Reduce("+", mapply(function(r, coef) r * coef,
                       raster_subset,
                       as.numeric(coef_vec[-1]),
                       SIMPLIFY = FALSE)) + as.numeric(coef_vec[1])
  }

  # extract bootstrap column indices
  loc_boot_idx <- grep(pattern="locCoeff", x=colnames(bootstraps))
  scl_boot_idx <- grep(pattern="scaleCoeff", x=colnames(bootstraps))
  shp_boot_idx <- grep(pattern="shapeCoeff", x=colnames(bootstraps))

  # build trend rasters for each bootstrap iteration + fitted model
  locs   <- vector("list", nrow(bootstraps) + 1)
  scales <- vector("list", nrow(bootstraps) + 1)
  shapes <- vector("list", nrow(bootstraps) + 1)

  for(k in 1:nrow(bootstraps)){
    locs[[k]]   <- build_trend_raster(as.numeric(bootstraps[k, loc_boot_idx]), loc.vars)
    scales[[k]] <- build_trend_raster(as.numeric(bootstraps[k, scl_boot_idx]), scl.vars)
    shapes[[k]] <- build_trend_raster(as.numeric(bootstraps[k, shp_boot_idx]), shp.vars)
  }

  # append the fitted model (last entry)
  fit.coef0 <- msp_fit$general_msp$param
  locs[[nrow(bootstraps) + 1]]   <- build_trend_raster(as.numeric(fit.coef0[grep("locCoeff",   names(fit.coef0))]),   loc.vars)
  scales[[nrow(bootstraps) + 1]] <- build_trend_raster(as.numeric(fit.coef0[grep("scaleCoeff",   names(fit.coef0))]), scl.vars)
  shapes[[nrow(bootstraps) + 1]] <- build_trend_raster(as.numeric(fit.coef0[grep("shapeCoeff",   names(fit.coef0))]), shp.vars)

  # extract trend raster values at subbasin target locations
  site.coords <- as.matrix(subbasin_targets)
  extract_pts <- function(raster_list){
    m <- matrix(NA, nrow=length(raster_list), ncol=nrow(site.coords))
    for(i in 1:length(raster_list)){
      m[i,] <- as.numeric(terra::extract(raster_list[[i]], terra::vect(site.coords, crs=ref_crs))[,-1])
    }
    m
  }

  locpts   <- extract_pts(locs)
  scalepts <- extract_pts(scales)
  shapepts <- extract_pts(shapes)




  ############################################################################
  # transform from frechet to gev
  ############################################################################

  sims_gev <- list()
  mean_gev <- matrix(NA,nrow=length(locs), ncol=nrow(sims[[1]]))

  for(i in 1:length(locs)){

    sims_gev[[i]] <- sims[[i]]

    for(j in 1:nrow(sims_gev[[i]])){
      sim.mat <- as.matrix(sims_gev[[i]])

      for(k in 1:nrow(site.coords)){
        sims_gev[[i]][j,k] <- SpatialExtremes::frech2gev(sim.mat[j,k], locpts[i,k], scalepts[i,k], shapepts[i,k])
      }

      mean_gev[i,j] <- stats::weighted.mean(x=sims_gev[[i]][j,], w=target_weights)
    }
    mean_gev[i,] <- sort(mean_gev[i,])
  }

  pps <- (1:ncol(mean_gev)) / (ncol(mean_gev) + 1)
  out <- data.frame(pp=(pps), aep=(1-pps), lower=apply(mean_gev,2,stats::quantile,probs=0.05), mean=apply(mean_gev,2,mean), model=mean_gev[nrow(mean_gev),], upper=apply(mean_gev,2,stats::quantile,probs=0.95))




  return(list(pf_curve=out, sims_frech=sims, sims_gev=sims_gev, mean_gev=mean_gev, target_locations=locpts, target_scales=scalepts, target_shapes=shapepts,
              msp_uncertainty=msp_uncertainty, msp_fit=msp_fit))
}
